# Production - intelmap.elderx.fi
intelmap.elderx.fi:80 {
  # Proxy API requests to the backend server (must come first)
  handle /api/* {
    reverse_proxy localhost:3000
  }

  # Proxy tile and WMS requests to cache-proxy
  handle /tiles/* {
    reverse_proxy localhost:8888
  }

  handle /wms/* {
    reverse_proxy localhost:8888
  }

  handle /osm-api/* {
    reverse_proxy localhost:8888
  }

  # Proxy all other requests to production web container
  reverse_proxy localhost:8080
}

# Staging - staging-intelmap.elderx.fi
staging-intelmap.elderx.fi:80 {
  # Proxy API requests to staging server
  handle /api/* {
    reverse_proxy localhost:3001
  }

  # Proxy tile and WMS requests to staging cache-proxy
  handle /tiles/* {
    reverse_proxy localhost:8889
  }

  handle /wms/* {
    reverse_proxy localhost:8889
  }

  handle /osm-api/* {
    reverse_proxy localhost:8889
  }

  # Proxy all other requests to staging web container
  reverse_proxy localhost:8081
} 
