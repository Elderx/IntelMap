# Production - intelmap.elderx.fi
intelmap.elderx.fi:80 {
  # Proxy API requests to the backend server (must come first)
  handle /api/* {
    reverse_proxy server:3000
  }

  # Proxy tile and WMS requests to cache-proxy (internal Docker network)
  handle /tiles/* {
    reverse_proxy cache-proxy:8888
  }

  handle /wms/* {
    reverse_proxy cache-proxy:8888
  }

  handle /osm-api/* {
    reverse_proxy cache-proxy:8888
  }

  handle_path /mml-map/* {
    root * /srv
    file_server
  }

  # Serve static files for all other requests
  root * /srv
  file_server
}

# Staging - staging-intelmap.elderx.fi
staging-intelmap.elderx.fi:80 {
  # Proxy API requests to staging server (must come first)
  handle /api/* {
    reverse_proxy intelmap-staging-server-1:3000
  }

  # Proxy tile and WMS requests to staging cache-proxy
  handle /tiles/* {
    reverse_proxy intelmap-staging-cache-proxy-1:8888
  }

  handle /wms/* {
    reverse_proxy intelmap-staging-cache-proxy-1:8888
  }

  handle /osm-api/* {
    reverse_proxy intelmap-staging-cache-proxy-1:8888
  }

  # Proxy all other requests to staging web container
  reverse_proxy intelmap-staging-web-1:80
} 
